
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model user{
  id String @id @default(uuid())
  email String @unique
  name String
  password String?
  workspaces workspace[]
  documents document[]
}

model workspace{
  id String @id @default(uuid())
  name String
  userId String
  slug String @unique
  documents document[]
  chats chat[]
  projects project[]
  user user @relation(fields: [userId], references: [id])
}

model document{
id String @id @default(uuid())
title String
workspaceId String
userId String
fileUrl String
fileName String
status String @default("processing")
createdAt DateTime @default(now())
projectId String
sections  section[]
chats chat[]
project project @relation(fields: [projectId],references: [id])
workspace workspace @relation(fields: [workspaceId], references: [id])
user user @relation(fields: [userId], references: [id])
}

model section{
  id  String @id @default(uuid())
  documentId String
  time String?
  title String
  content String
  keywords String
  document document @relation(fields: [documentId], references: [id])
}

model chat{
  id String @id @default(uuid())
  message String
  userId String
  documentId String
  workspaceId String
  workspace workspace @relation(fields: [workspaceId],references: [id])
  document document @relation(fields: [documentId],references: [id])
}

model project{
  id String @unique @default(uuid())
  name String
  workspaceId String
  userId String
  documents document[]
  workspace workspace @relation(fields: [workspaceId],references: [id])
}